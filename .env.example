# ZAFIRIX PRO — copy to `.env.local` for development. Set the same keys in Vercel (Production / Preview).

# Supabase (public; safe to expose in the browser bundle)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role — SERVER-SIDE ONLY. Never prefix with NEXT_PUBLIC_.
# Used by API routes and server middleware for privileged operations (admin, webhooks, etc.).
# Do not expose this value to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Canonical site origin for auth redirects (password reset, etc.).
# Local development:
#   NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production (Vercel or your domain):
#   NEXT_PUBLIC_SITE_URL=https://your-domain.example
NEXT_PUBLIC_SITE_URL=
